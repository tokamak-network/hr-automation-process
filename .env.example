AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o-mini
GITHUB_TOKEN=ghp_your-token-here
ECOS_API_KEY=your-ecos-key-here
ETHERSCAN_API_KEY=your-etherscan-key-here
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
HR_DB_PATH=
EXPENSE_TRIGGER_DAY=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# C-1 채용 메일 인테이크 (Gmail 읽기 전용). 값/토큰 커밋 금지.
GMAIL_USER=hr@tokamak.network
GMAIL_TOKEN_PATH=backend/gmail_token.json
GMAIL_CREDENTIALS_PATH=backend/gmail_credentials.json
CANDIDATE_SCAN_DAYS=14
# 자동 스캔 요일 (월=0 ... 일=6). 기본 월·목 = 주 2회.
INTAKE_SCAN_WEEKDAYS=0,3
# 내부(우리 측) 발신자 제외 — 스레드에서 우리가 답장한 메일을 후보로 안 잡게.
INTAKE_INTERNAL_DOMAINS=tokamak.network
INTAKE_INTERNAL_EMAILS=hr@tokamak.network,jaden@tokamak.network
# 팀원 GitHub 핸들 (리뷰어 매칭용). 콤마 구분. 미설정 시 backend/team_members.json(gitignore) 사용.
# 실제 핸들은 여기 넣지 말 것 — 형식 예시만.
TEAM_MEMBERS=handle1,handle2,handle3
